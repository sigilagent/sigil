#!/usr/bin/env bash
# sigil — talk to your Sigil agent.
#
# Runs locally by default — no server needed:
#   sigil solve "turn report.pdf into a clean CSV"
#   sigil soul | tasks list | models list | teach "…" | recall "…"
#   sigil chat | config                # interactive
#   sigil add-mcp github stdio gh-mcp  # give it tools
#   sigil register-skill ./skill.agir agir
#   sigil update                       # update to the latest release
#
# Prefer a server + web dashboard? Start the gateway, then point at it:
#   sigil serve                        # Observatory web UI + HTTP API
#   export SIGIL_URL=http://localhost:8199   # route commands to that gateway
#   sigil login                        # once — caches a JWT
#
# Config via env:  SIGIL_SESSION · SIGIL_URL (gateway) · SIGIL_USER / SIGIL_PASS · SIGIL_JAC
set -euo pipefail

URL="${SIGIL_URL:-http://localhost:8199}"
HERE="$(cd "$(dirname "$0")" && pwd)"
JAC="${SIGIL_JAC:-$(command -v jac || echo "$HOME/.local/bin/jac")}"
TOKFILE="${SIGIL_TOKENFILE:-$HOME/.sigil/token}"
TOKEN="${SIGIL_TOKEN:-$(cat "$TOKFILE" 2>/dev/null || true)}"

esc() { python3 -c 'import json,sys; print(json.dumps(sys.argv[1]))' "$1"; }

# POST JSON to /walker/<name>, unwrap the jac-cloud reports envelope.
call() {
  local walker="$1" body="${2:-}" auth=()
  [ -z "$body" ] && body='{}'
  [ -n "$TOKEN" ] && auth=(-H "Authorization: Bearer $TOKEN")
  curl -sS -X POST "$URL/walker/$walker" \
       -H "Content-Type: application/json" "${auth[@]}" \
       --max-time "${SIGIL_TIMEOUT:-600}" -d "$body" \
  | python3 -c '
import sys, json
try: d = json.load(sys.stdin)
except Exception as e: print("bad response:", e); sys.exit(1)
if not d.get("ok", True):
    msg = (d.get("error") or {}).get("message", d)
    if str(msg) == "Unauthorized": msg = "Unauthorized — run: sigil login"
    print("ERROR:", msg); sys.exit(1)
reps = (((d.get("data") or {}).get("result") or {}).get("reports")) or [d]
r = reps[0] if reps else {}
print(json.dumps(r, indent=2, ensure_ascii=False) if isinstance(r,(dict,list)) else r)
'
}

login() {
  local user="${SIGIL_USER:-owner}" pass="${SIGIL_PASS:-sigil-dev}"
  # register is idempotent for our purposes (ignore "already exists")
  curl -sS -X POST "$URL/user/register" -H "Content-Type: application/json" -d \
    "{\"identities\":[{\"type\":\"username\",\"value\":$(esc "$user")}],\"credential\":{\"type\":\"password\",\"password\":$(esc "$pass")}}" \
    >/dev/null 2>&1 || true
  local R; R=$(curl -sS -X POST "$URL/user/login" -H "Content-Type: application/json" -d \
    "{\"identity\":{\"type\":\"username\",\"value\":$(esc "$user")},\"credential\":{\"type\":\"password\",\"password\":$(esc "$pass")}}")
  local T; T=$(echo "$R" | python3 -c 'import sys,json; d=json.load(sys.stdin); print((d.get("data") or {}).get("token") or d.get("token") or "")')
  [ -z "$T" ] && { echo "login failed: $R" >&2; exit 1; }
  mkdir -p "$(dirname "$TOKFILE")"; printf '%s' "$T" > "$TOKFILE"; chmod 600 "$TOKFILE"
  echo "logged in as '$user' — token cached at $TOKFILE"
}

cmd="${1:-help}"; shift || true
case "$cmd" in
  serve)      exec "$JAC" start --dev "$HERE/observatory.jac" --port "${SIGIL_PORT:-8199}" -a "${SIGIL_API_PORT:-8198}" ;;
  login)      login ;;
  update)     echo "Updating Sigil to the latest release…"
              exec bash -c 'curl -fsSL "${SIGIL_INSTALL_URL:-https://github.com/sigilagent/sigil/releases/latest/download/install.sh}" | bash' ;;
  help|"")    awk 'NR==1{next} /^#/{sub(/^# ?/,"");print;next}{exit}' "$0" ;;
  *)
    # LOCAL by default — run the full CLI straight through main.jac, no server.
    # Export SIGIL_URL to talk to a running gateway (sigil serve) instead.
    if [ -z "${SIGIL_URL+set}" ]; then
      [ "$cmd" = "local" ] && { cmd="${1:-help}"; shift || true; }
      exec "$JAC" run "$HERE/main.jac" -s "${SIGIL_SESSION:-$HOME/.sigil/agent.session}" -- "$cmd" "$@"
    fi
    # GATEWAY mode — SIGIL_URL is set: POST to the running agent's HTTP endpoints.
    case "$cmd" in
      solve)      call api_solve         "{\"task\": $(esc "${1:?usage: sigil solve \"<task>\"}")}" ;;
      chat)       call api_chat_completions "{\"messages\":[{\"role\":\"user\",\"content\": $(esc "${1:?usage: sigil chat \"<msg>\"}")}]}" ;;
      soul)       call api_soul ;;
      configure)  call api_configure     "{\"key\": $(esc "${1:?key}"), \"value\": $(esc "${2:?value}")}" ;;
      recall)     call api_recall        "{\"query\": $(esc "${1:?usage: sigil recall \"<query>\"}")}" ;;
      library)    call api_library ;;
      graph)      call api_graph ;;
      tokens)     call api_observability "{\"n\": ${1:-100}}" ;;
      mcp)        call api_mcp ;;
      teach)      call api_teach         "{\"fact\": $(esc "${1:?usage: sigil teach \"<fact>\"}")}" ;;
      add-mcp)    call api_add_mcp       "{\"name\": $(esc "${1:?name}"), \"transport\": $(esc "${2:-stdio}"), \"target\": $(esc "${3:?cmd-or-url}")}" ;;
      register-skill)
                  src="${1:?usage: sigil register-skill <path> [md|agir|osp]}"; kind="${2:-agir}"
                  payload="${src}"; [ "$kind" != "osp" ] && payload="$(cat "$src")"
                  call api_register_skill "{\"source\": $(esc "$payload"), \"kind\": $(esc "$kind")}" ;;
      *)          echo "sigil: '$cmd' isn't available over the gateway — unset SIGIL_URL to run it locally." >&2; exit 1 ;;
    esac
    ;;
esac
